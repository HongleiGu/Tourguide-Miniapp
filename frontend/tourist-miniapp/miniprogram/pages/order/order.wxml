<view class="page" wx:if="{{order}}">
  <view class="card">
    <view class="status status-{{order.status}}">{{order.statusLabel}}</view>
    <view class="title">{{order.sessionTitle}}</view>
    <view class="line"><text class="k">订单号</text><text class="v">{{order.orderNo}}</text></view>
    <view class="line"><text class="k">人数</text><text class="v">{{order.peopleCount}}</text></view>
    <view class="line"><text class="k">金额</text><text class="v price">¥{{order.amountYuan}}</text></view>
  </view>

  <view wx:if="{{order.status === 'PAID' && order.verifyCode}}" class="card verify">
    <view class="verify-label">核销码</view>
    <view class="verify-code">{{order.verifyCode}}</view>
    <view class="muted">出示给讲解员扫码核销</view>
  </view>

  <view wx:if="{{order.status === 'COMPLETED'}}" class="card review">
    <view class="verify-label">评价</view>

    <block wx:if="{{review}}">
      <view class="stars">
        <text wx:for="{{stars}}" wx:key="*this" class="star {{item <= review.rating ? 'on' : ''}}">★</text>
      </view>
      <view wx:if="{{review.content}}" class="review-content">{{review.content}}</view>
      <view class="muted">{{review.createdAt}}</view>
    </block>

    <block wx:else>
      <view class="stars">
        <text
          wx:for="{{stars}}"
          wx:key="*this"
          class="star {{item <= ratingInput ? 'on' : ''}}"
          data-n="{{item}}"
          bindtap="setRating"
        >★</text>
      </view>
      <textarea class="review-input" placeholder="说说这次讲解体验…" value="{{contentInput}}" bindinput="onReviewContent" />
      <button class="btn" type="primary" loading="{{submittingReview}}" bindtap="submitReviewTap">提交评价</button>
    </block>
  </view>

  <button wx:if="{{order.status === 'PENDING_PAYMENT'}}" class="btn" type="primary" loading="{{paying}}" bindtap="pay">
    模拟支付
  </button>
  <button wx:if="{{order.cancellable}}" class="btn" loading="{{cancelling}}" bindtap="cancel">取消订单</button>
  <button class="btn" bindtap="goHome">返回首页</button>
</view>
