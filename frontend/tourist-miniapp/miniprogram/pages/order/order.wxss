.page {
  padding: 24rpx;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.status {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.status-PAID {
  color: #389e0d;
}
.status-PENDING_PAYMENT {
  color: #d48806;
}
.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 12rpx;
}
.line {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
}
.k {
  color: #909399;
  font-size: 26rpx;
}
.v {
  color: #1f2329;
  font-size: 26rpx;
}
.price {
  color: #d4380d;
  font-weight: 600;
}
.verify {
  text-align: center;
}
.verify-label {
  font-size: 26rpx;
  color: #909399;
}
.qr {
  width: 320rpx;
  margin: 16rpx auto 0;
  display: block;
}
.verify-code {
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #1f3a5f;
  margin: 16rpx 0;
}
.muted {
  font-size: 22rpx;
  color: #c0c4cc;
}
.btn {
  margin-top: 20rpx;
}
.stars {
  margin: 12rpx 0;
}
.star {
  font-size: 48rpx;
  color: #dcdfe6;
  margin-right: 8rpx;
}
.star.on {
  color: #fadb14;
}
.review-content {
  font-size: 26rpx;
  color: #1f2329;
  margin: 8rpx 0;
}
.review-input {
  width: 100%;
  box-sizing: border-box;
  min-height: 140rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  margin-top: 8rpx;
}
