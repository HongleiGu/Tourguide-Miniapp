.page {
  padding: 24rpx;
}
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.brand {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f3a5f;
}
.mine {
  font-size: 26rpx;
  color: #2c5282;
}
.banner {
  background: #fff7e6;
  border: 1rpx solid #ffe1a8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
}
.ann {
  font-size: 24rpx;
  color: #8a6d3b;
  line-height: 1.6;
}
.hd {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f3a5f;
  margin: 8rpx 0 16rpx;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}
.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 14rpx;
}
.tag {
  font-size: 22rpx;
  color: #2c5282;
  background: #ebf3ff;
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
}
.tag.group {
  color: #ad6800;
  background: #fff7e6;
  margin-left: 8rpx;
}
.price {
  font-size: 30rpx;
  font-weight: 600;
  color: #d4380d;
}
.muted {
  font-size: 24rpx;
  color: #909399;
}
.center {
  text-align: center;
  padding: 60rpx 0;
}
