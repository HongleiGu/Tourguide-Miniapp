  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.hd {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f3a5f;
  margin-bottom: 12rpx;
}
.line {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
}
.k {
  color: #909399;
  font-size: 26rpx;
}
.v {
  color: #1f2329;
  font-size: 26rpx;
}
.small {
  font-size: 22rpx;
