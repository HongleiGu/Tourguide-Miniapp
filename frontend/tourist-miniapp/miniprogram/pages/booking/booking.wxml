<view class="page">
  <view class="card">
    <view class="title">{{title}}</view>
    <text class="tag">{{typeLabel}}</text>
  </view>

  <view class="card form">
    <view class="row">
      <text class="label">人数</text>
      <input class="input" type="number" value="{{peopleCount}}" bindinput="onPeople" />
    </view>
    <view class="row">
      <text class="label">联系人</text>
      <input class="input" placeholder="请输入姓名" value="{{contactName}}" bindinput="onName" />
    </view>
    <view class="row">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{contactPhone}}" bindinput="onPhone" />
    </view>
  </view>

  <view class="footer">
    <view class="total">合计 <text class="price">¥{{totalYuan}}</text></view>
    <button class="submit" type="primary" loading="{{submitting}}" bindtap="submit">立即预约</button>
  </view>
</view>
