<view class="page" wx:if="{{order}}">
  <view class="card">
    <view class="status status-{{order.status}}">{{order.statusLabel}}</view>
    <view class="title">{{order.sessionTitle}}</view>
    <view class="line"><text class="k">日期</text><text class="v">{{order.date}}</text></view>
    <view class="line"><text class="k">集合时间</text><text class="v">{{order.timeRange || '—'}}</text></view>
    <view class="line"><text class="k">人数</text><text class="v">{{order.peopleCount}}</text></view>
    <view class="line"><text class="k">订单号</text><text class="v">{{order.orderNo}}</text></view>
  </view>

  <view class="card">
    <view class="card-title">游客信息</view>
    <view class="line"><text class="k">联系人</text><text class="v">{{order.contactName || '—'}}</text></view>
    <view class="line"><text class="k">电话</text><text class="v">{{order.contactPhone || '—'}}</text></view>
  </view>
</view>

<view wx:elif="{{!loading}}" class="muted center">订单不存在或无权访问</view>
