.page {
  padding: 24rpx;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.status {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: #d48806;
}
.status-COMPLETED {
  color: #389e0d;
}
.status-CANCELLED,
.status-REFUNDED {
  color: #cf1322;
}
.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 12rpx;
}
.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 12rpx;
}
.line {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
}
.k {
  color: #909399;
  font-size: 26rpx;
}
.v {
  color: #1f2329;
  font-size: 26rpx;
}
.muted {
  color: #909399;
  font-size: 26rpx;
}
.center {
  text-align: center;
  padding: 60rpx 0;
}
