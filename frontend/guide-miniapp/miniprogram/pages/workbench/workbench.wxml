<view class="page">
  <view wx:if="{{loading}}" class="muted center">加载中…</view>

  <block wx:elif="{{board}}">
    <view class="header">
      <text class="date">{{board.date}}</text>
      <text class="badge {{board.accepting ? 'on' : 'off'}}">{{board.accepting ? '接单中' : '已关闭'}}</text>
    </view>

    <view class="stats">
      <view class="stat">
        <view class="num">{{board.pendingAcceptCount}}</view>
        <view class="label">待接单</view>
      </view>
      <view class="stat">
        <view class="num">{{board.toVerifyCount}}</view>
        <view class="label">待核销</view>
      </view>
      <view class="stat">
        <view class="num">{{board.completedCount}}</view>
        <view class="label">已完成</view>
      </view>
    </view>

    <view class="card">
      <view class="row">
        <text class="k">今日是否上班</text>
        <text class="v">{{board.onDutyToday ? '是' : '否'}}</text>
      </view>
      <view class="row">
        <text class="k">剩余可接单数</text>
        <text class="v">{{board.remainingCapacity}}</text>
      </view>
    </view>

    <view class="actions">
      <button class="action" type="primary" bindtap="goScan">扫码核销</button>
      <button class="action" bindtap="goPool">抢单</button>
    </view>

    <view class="card">
      <view class="card-title">当日排班</view>
      <view wx:if="{{!schedule.length}}" class="muted">今日无排班</view>
      <view wx:for="{{schedule}}" wx:key="id" class="row">
        <text class="k">{{item.typeLabel}}</text>
        <text class="v">{{item.range}}</text>
      </view>
    </view>
  </block>

  <view wx:else class="muted center">无法加载工作台</view>
</view>
