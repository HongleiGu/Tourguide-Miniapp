<view class="page">
  <button class="btn" type="primary" loading="{{busy}}" bindtap="scan">扫一扫核销</button>

  <view class="card">
    <view class="card-title">或手动输入核销码</view>
    <input class="input" placeholder="请输入核销码" value="{{code}}" bindinput="onCode" />
    <button class="btn" loading="{{busy}}" bindtap="submit">核销</button>
  </view>

  <view wx:if="{{result}}" class="card ok">
    <view class="ok-title">核销成功</view>
    <view class="line"><text class="k">场次</text><text class="v">{{result.sessionTitle}}</text></view>
    <view class="line"><text class="k">人数</text><text class="v">{{result.peopleCount}}</text></view>
    <view class="line"><text class="k">订单号</text><text class="v">{{result.orderNo}}</text></view>
  </view>

  <view wx:if="{{error}}" class="error">{{error}}</view>
</view>
