.page {
  padding: 24rpx;
}
.hint {
  font-size: 26rpx;
  color: #909399;
  margin-bottom: 16rpx;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.row:last-child {
  margin-bottom: 0;
}
.title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
}
.muted {
  font-size: 24rpx;
  color: #909399;
}
.grab {
  margin: 0;
}
.center {
  text-align: center;
  padding: 60rpx 0;
}
