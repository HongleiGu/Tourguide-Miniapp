<view class="page">
  <view wx:if="{{loading}}" class="muted center">加载中…</view>

  <view wx:elif="{{me}}" class="card">
    <view class="name">{{me.name || '讲解员'}}</view>
    <view class="row"><text class="k">类型</text><text class="v">{{me.employmentLabel}}</text></view>
    <view class="row"><text class="k">接单状态</text><text class="v">{{me.acceptingOrders ? '开启' : '关闭'}}</text></view>
    <view class="row"><text class="k">账号状态</text><text class="v">{{me.status}}</text></view>
    <view class="row"><text class="k">评分</text><text class="v">{{me.rating}} · {{me.starLevel}}★</text></view>
  </view>

  <view wx:else class="muted center">未登录或非讲解员账号</view>

  <button class="btn" bindtap="doLogout">退出登录</button>
</view>
