# Copy to .env and fill in real values. NEVER commit .env.

# ---- Jira (tooling: tools/jira.py) ----
JIRA_SITE=https://your-site.atlassian.net/
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-atlassian-api-token

# ---- Backend: Runtime ----
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ---- Backend: Database (MySQL 8) ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tourguide
DB_USER=tourguide
DB_PASSWORD=changeme

# ---- Backend: Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Backend: Auth ----
JWT_SECRET=change-this-to-a-long-random-string
# Token lifetimes (ISO-8601 duration). Optional; defaults: access PT2H, refresh P7D.
JWT_ACCESS_TTL=PT2H
JWT_REFRESH_TTL=P7D

# ---- WeChat Mini Program ----
WX_APPID=wxa56ca2b2ce0b579e
WX_APP_SECRET=your-wechat-app-secret

# ---- WeChat Pay (v3) ----
WXPAY_MCHID=your-merchant-id
WXPAY_APIV3_KEY=your-apiv3-key
WXPAY_CERT_SERIAL=your-cert-serial-no
WXPAY_NOTIFY_URL=https://your-domain/api/pay/notify
