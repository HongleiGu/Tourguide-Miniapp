# Normalize line endings: LF in the repo, auto on checkout
* text=auto eol=lf

# Windows-specific scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Gradle wrapper script stays LF/executable
gradlew text eol=lf

# Binary files — never normalize
*.docx binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.woff binary
*.woff2 binary
